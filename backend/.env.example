PORT=5000
JWT_SECRET=your_jwt_signing_secret_here

# Database Configuration (Amazon RDS / MySQL)
DB_HOST=localhost
DB_USER=root
DB_PASSWORD=your_password
DB_NAME=student_grievance
DB_PORT=3306

# AWS Credentials
# Note: If deploying to AWS EC2 with an attached IAM Role, these credentials can be left blank.
# The AWS SDK will automatically resolve credentials via the EC2 Instance Metadata Service (IMDS).
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=your_access_key
AWS_SECRET_ACCESS_KEY=your_secret_key

# AWS Services Configuration
AWS_S3_BUCKET_NAME=student-grievance-evidence-bucket
AWS_SNS_TOPIC_ARN=arn:aws:sns:us-east-1:123456789012:student-grievance-notifications
